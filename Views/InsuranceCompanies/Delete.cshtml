@model InsuranceCompany

<h1 style="background-color:lightgray; color:darkslategray">Details:</h1>

<dl class="row">
    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.InsuranceCompanyId)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.InsuranceCompanyId)</center></dd>

    <dt class="col-2"><center></center>@Html.DisplayNameFor(item => item.InsuranceCompanyName)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.InsuranceCompanyName)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.DiscountPercentage)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.DiscountPercentage)</center></dd>
</dl>

<hr />
<form method="post" asp-controller="InsuranceCompanies" asp-action="Delete">

    <input hidden asp-for="InsuranceCompanyId" />
    <button type="submit" class=" btn btn-danger">Delete</button>

</form>
<hr />
<a asp-controller="InsuranceCompanies" asp-action="Index"><i class="fas fa-undo-alt"></i></a>