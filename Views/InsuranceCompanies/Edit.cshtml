@model InsuranceCompany

<h1 style="background-color:lightgray; color:darkslategray">Edit:</h1>

<form method="post" asp-controller="InsuranceCompanies" asp-action="Edit">

    <input hidden asp-for="InsuranceCompanyId" />

    <div class="row">
        <label asp-for="InsuranceCompanyName" class="col-5"></label>
        <input asp-for="InsuranceCompanyName" class="col-4 form-control" />
        <span class="text-danger" asp-validation-for="InsuranceCompanyName"></span>
    </div>

    <div class="row">
        <label asp-for="DiscountPercentage" class="col-5"></label>
        <input asp-for="DiscountPercentage" class="col-4 form-control" />
        <span class="text-danger" asp-validation- for="Age"></span>
    </div>

    <button type="submit" class="btn btn-primary">save</button>
    <hr />
    <a asp-controller="InsuranceCompanies" asp-action="index"><i class="fas fa-undo-alt"></i></a>
    <br />
    <div asp-validation-summary="All"></div>
</form>