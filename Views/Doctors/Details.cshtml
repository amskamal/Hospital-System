    <dd class="col-10"><center>@Html.DisplayFor(item => item.PhoneNo1)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.PhoneNo2)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.PhoneNo2)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.Email)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.Email)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.DoctorBirthDate)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.DoctorBirthDate)</center></dd>
</dl>

<hr />
<a asp-controller="Doctors" asp-action="index"><i class="fas fa-undo-alt"></i></a> |
<a asp-controller="Doctors" asp-action="Edit" asp-route-id="@Model.DocId">
    <i class="far fa-edit"></i>
</a>