@model Doctor

<h1 style="background-color:lightgray; color:darkslategray">Details:</h1>

<dl class="row">
    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.DocId)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.DocId)</center></dd>

    <dt class="col-2"><center></center>@Html.DisplayNameFor(item => item.DoctorName)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.DoctorName)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.DepartmentId)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.Department.DepartmentName)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.DoctorScienceDegrees)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.DoctorScienceDegrees)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.DegreeDate)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.DegreeDate)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.DoctorDaysPerWeek)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.DoctorDaysPerWeek)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.DoctorTimePerDay)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.DoctorTimePerDay)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.CheckUpFee)</center></dt>
