@model Patient

<h1 style="background-color:lightgray; color:darkslategray">Details:</h1>

<dl class="row">
    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.PatientId)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.PatientId)</center></dd>

    <dt class="col-2"><center></center>@Html.DisplayNameFor(item => item.PatientName)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.PatientName)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.Age)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.Age)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.PhoneNo)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.PhoneNo)</center></dd>

    <dt class="col-2"><center>@Html.DisplayNameFor(item => item.Email)</center></dt>
    <dd class="col-10"><center>@Html.DisplayFor(item => item.Email)</center></dd>
</dl>

<hr />
<a asp-controller="Patients" asp-action="index"><i class="fas fa-undo-alt"></i></a> |
<a asp-controller="Patients" asp-action="Edit" asp-route-id="@Model.PatientId">
    <i class="far fa-edit"></i>
</a>